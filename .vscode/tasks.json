{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build:debug",
            "type": "shell",
            "command": "bazel",
            "args": [
                "build",
                "//src/encoding:encoding", // set your BUILD
                "--config=debug"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            "label": "build:release",
            "type": "shell",
            "command": "bazel",
            "args": [
                "build",
                "//src/encoding:encoding", // set your BUILD
                "--config=release"
            ],
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ]
        },
        {
            // bazel-compile-commands default support ./bazel-out/x64_windows-fastbuild/... path, so need it
            "label": "build:fastbuild",
            "type": "shell",
            "command": "bazel",
            "args": [
                "build",
                "//src/encoding:encoding" // set your BUILD
            ]
        },
        // Use the official Bazel-recommended compile_commands.
        // json generator from kiron1 to enable clang-tidy for code analysis
        // See: http://bazel.build/install/ide
        //
        // You need to download its binary (.exe) and add the directory path
        // to your PATH environment variable in order to use it.
        //
        // Typically, you only need to trigger it to rebuild compile_commands.json
        // when there are changes to your BUILD or MODULE.bazel files.
        {
            "label": "Run bazel-compile-commands",
            "command": "bazel-compile-commands",
            "type": "shell",
            "isBackground": true,
            "hide": true
        },
        {
            "label": "clang-tidy:refresh",
            "command": "${command:clangd.restart}",
            "isBackground": true,
            "dependsOn": [
                "build:fastbuild",
                "Run bazel-compile-commands"
            ],
            "group": {
                "kind": "build"
            }
        }
    ]
}
